PORT=3000

# Azure OpenAI base endpoint, example:
# https://<your-resource-name>.openai.azure.com
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# Realtime deployment name in Azure OpenAI
AZURE_OPENAI_REALTIME_DEPLOYMENT=

# Vision-capable deployment name in Azure OpenAI (used by /api/analyze-image)
AZURE_OPENAI_VISION_DEPLOYMENT=

# Chat Completions API version used for image analysis endpoint
AZURE_OPENAI_API_VERSION=2024-10-21

# Max upload size for /api/analyze-image
MAX_UPLOAD_BYTES=8388608

# Event retention and Redis
RETENTION_HOURS=24
REDIS_URL=redis://localhost:6379

# Worker tuning
ANALYSIS_TIMEOUT_MS=25000
STORAGE_CLEANUP_INTERVAL_MS=60000

# Rate limiting and logging
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
WS_RATE_LIMIT_MAX=30
LOG_REQUESTS=0
LOG_LEVEL=info
LOG_JSON=1

# CORS (comma-separated origins). Leave empty for open CORS in dev.
CORS_ORIGIN=

# Realtime intent -> capture orchestration tuning
INTENT_CAPTURE_CONFIDENCE_THRESHOLD=0.65
INTENT_CAPTURE_COOLDOWN_SEC=8
ANALYSIS_FAIL_FALLBACK_LIMIT=2
